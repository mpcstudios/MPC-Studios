# MPC Studios — TinaCMS Self-Hosted Configuration
#
# In production, all values come from Infisical via the Vercel sync — you don't
# fill these in by hand on a deployed site. This file is only useful as a
# reference for what the runtime expects.
#
# For local prod-mode dev, run `pnpm dev:prod` — Infisical injects everything
# from `websites/prod/sites/mpc-studios` (with `${prod.shared.*}` references
# resolved). No `.env.local` needed.

# GitHub App auth (commits content edits as mpc-studios-cms[bot])
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# Optional GitHub overrides (defaults read from VERCEL_GIT_* on Vercel)
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=

# NextAuth.js (admin sign-in JWT signing key)
NEXTAUTH_SECRET=

# Upstash Redis (TinaCMS database layer)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# AWS S3 (media uploads) — shared mpcstudios-media bucket
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET=mpcstudios-media
S3_MEDIA_ROOT=mpc-studios
